{
  "name": "Hackathon-Goa---Team-14",
  "version": "1.0.0",
  "description": "AI-powered PR workflow agent for SAP GitHub repos",
  "type": "module",
  "main": "src/agent/index.js",
  "scripts": {
    "start": "node src/agent/index.js",
    "conflict-resolver": "node src/conflict-resolver/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^21.0.0",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.7.2",
    "jest": "^29.0.0"
  },
  "cds": {
    "requires": {
      "db-ext": {
        "[development]": {
          "model": "db/sqlite"
        },
        "[production]": {
          "model": "db/hana"
        }
      }
    }
  },
  "engines": {
    "node": ">=20"
  }
}
